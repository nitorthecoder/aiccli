{
  "$schema": "https://raw.githubusercontent.com/nitorthecoder/ccaitmpl/main/schemas/aiccli.json",
  "name": "AICCLI",
  "version": "1.0.0",
  "description": "AI Components Library for OpenCode CLI",
  "components": {
    "$ref": "./components.json"
  },
  "install": {
    "agents": {
      "directory": ".opencode/agents",
      "extension": ".agent.json"
    },
    "skills": {
      "directory": ".opencode/skills",
      "extension": ".skill.json"
    },
    "commands": {
      "directory": ".opencode/commands",
      "extension": ".command.json"
    },
    "mcps": {
      "directory": ".opencode/mcps",
      "extension": ".mcp.json"
    },
    "hooks": {
      "directory": ".opencode/hooks",
      "extension": ".hook.json"
    },
    "settings": {
      "directory": ".opencode/settings",
      "extension": ".setting.json"
    }
  },
  "keywords": ["ai", "claude", "opencode", "agents", "skills", "commands", "mcp", "hooks"]
}
